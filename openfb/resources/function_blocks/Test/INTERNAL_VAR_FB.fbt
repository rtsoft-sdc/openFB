				<Attribute Name="VarConfig" Value="true"/>
			</VarDeclaration>
			<VarDeclaration Name="WORD_IN" Type="WORD">
				<Attribute Name="VarConfig" Value="true"/>
			</VarDeclaration>
			<VarDeclaration Name="WSTRING_IN" Type="WSTRING">
				<Attribute Name="VarConfig" Value="true"/>
			</VarDeclaration>
