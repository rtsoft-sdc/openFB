<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="INTERNAL_VAR_FB" Comment="Simple FB with one algorithm">
	<Identification Standard="61499-1">
	</Identification>
	<VersionInfo Version="1.1" Author="steamdragon" Date="2025-08-19">
	</VersionInfo>
	<CompilerInfo>
	</CompilerInfo>
