<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="E_TABLE" Comment="Composite Function Block Type">
	<InterfaceList>
		<EventInputs>
			<Event Name="START" Type="Event" Comment="Start table driven event generation">
				<With Var="DT"/>
				<With Var="N"/>
			</Event>
			<Event Name="STOP" Type="Event" Comment="Stop table driven event generation">
			</Event>
		</EventInputs>
		<EventOutputs>
			<Event Name="EO" Type="Event" Comment="Generated events: N events at periods DT, starting at DT[0] after START">
				<With Var="CV"/>
			</Event>
		</EventOutputs>
		<InputVars>
			<VarDeclaration Name="DT" Type="TIME" Comment="Periods between events" ArraySize="4"/>
			<VarDeclaration Name="N" Type="UINT" Comment="Number of events to generate"/>
		</InputVars>
		<OutputVars>
			<VarDeclaration Name="CV" Type="UINT" Comment="Current event index, 0..N-1"/>
		</OutputVars>
	</InterfaceList>
	<FBNetwork>
		<FB Name="E_TABLE_CTRL" Type="iec61499::events::E_TABLE_CTRL" x="-780" y="633.33">
		</FB>
		<FB Name="E_DELAY" Type="iec61499::events::E_DELAY" x="606.67" y="633.33">
		</FB>
		<EventConnections>
			<Connection Source="E_TABLE_CTRL.CLKO" Destination="E_DELAY.START" dx1="273.33"/>
			<Connection Source="E_DELAY.EO" Destination="EO" dx1="1380"/>
			<Connection Source="START" Destination="E_TABLE_CTRL.INIT" dx1="473.33"/>
			<Connection Source="E_DELAY.EO" Destination="E_TABLE_CTRL.CLK" dx1="73.33" dx2="73.33" dy="-240"/>
			<Connection Source="STOP" Destination="E_DELAY.STOP" dx1="1460"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="E_TABLE_CTRL.DTO" Destination="E_DELAY.DT" dx1="73.33"/>
			<Connection Source="E_TABLE_CTRL.CV" Destination="CV" dx1="1960"/>
			<Connection Source="DT" Destination="E_TABLE_CTRL.DT" dx1="280"/>
			<Connection Source="N" Destination="E_TABLE_CTRL.N" dx1="280"/>
		</DataConnections>
	</FBNetwork>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
