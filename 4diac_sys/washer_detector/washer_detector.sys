					<Connection Source="washer_detectorApp.E_CYCLE.EO" Destination="washer_detectorApp.E_SWITCH.EI" dx1="358.82"/>
					<Connection Source="START.COLD" Destination="washer_detectorApp.E_CYCLE.START" dx1="547.06"/>
					<Connection Source="START.WARM" Destination="washer_detectorApp.E_CYCLE.START" dx1="364.71"/>
					<Connection Source="START.STOP" Destination="washer_detectorApp.E_CYCLE.STOP" dx1="70.59"/>
					<Connection Source="START.COLD" Destination="washer_detectorApp.PUBLISH_1.INIT" dx1="2364.71"/>
					<Connection Source="START.WARM" Destination="washer_detectorApp.PUBLISH_1.INIT" dx1="2211.76"/>
				</EventConnections>
			</FBNetwork>
