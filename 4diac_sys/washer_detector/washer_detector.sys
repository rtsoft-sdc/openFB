	</Device>
	<Segment Name="Ethernet" Type="Ethernet" x="3005.88" y="705.88" dx1="1764.71">
		<Attribute Name="Color" Type="STRING" Value="206,116,130"/>
	</Segment>
	<Mapping From="washer_detectorApp.CAMERA" To="FORTE_PC.EMB_RES"/>
