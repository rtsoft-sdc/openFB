				</FB>
				<EventConnections>
					<Connection Source="washer_detectorApp.PY_MQTT_SUB.INITO" Destination="washer_detectorApp.CAMERA.INIT"/>
					<Connection Source="washer_detectorApp.PY_MQTT_SUB.CNF" Destination="washer_detectorApp.CAMERA.RSP"/>
					<Connection Source="washer_detectorApp.CAMERA.INIT0" Destination="washer_detectorApp.Detector_N_Drawer.INIT"/>
					<Connection Source="washer_detectorApp.CAMERA.IND" Destination="washer_detectorApp.Detector_N_Drawer.REQ"/>
					<Connection Source="washer_detectorApp.Detector_N_Drawer.INITO" Destination="washer_detectorApp.IMG_QUEUE_DELETE.INIT"/>
					<Connection Source="washer_detectorApp.Detector_N_Drawer.CNF" Destination="washer_detectorApp.IMG_QUEUE_DELETE.RSP"/>
