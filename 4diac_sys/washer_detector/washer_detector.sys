				</EventConnections>
				<DataConnections>
					<Connection Source="washer_detectorApp.PY_MQTT_SUB.QO" Destination="washer_detectorApp.CAMERA.QI"/>
					<Connection Source="washer_detectorApp.CAMERA.QO" Destination="washer_detectorApp.Detector_N_Drawer.QI"/>
					<Connection Source="washer_detectorApp.CAMERA.IMG_ID" Destination="washer_detectorApp.Detector_N_Drawer.IMG_ID"/>
					<Connection Source="washer_detectorApp.Detector_N_Drawer.QO" Destination="washer_detectorApp.IMG_QUEUE_DELETE.QI"/>
					<Connection Source="washer_detectorApp.Detector_N_Drawer.IMG_IDO" Destination="washer_detectorApp.IMG_QUEUE_DELETE.IMG_ID"/>
				</DataConnections>
			</FBNetwork>
		</Resource>
	</Device>
	<Device Name="FORTE_PC_1" Type="FORTE_PC" x="5011.76" y="1752.94">
