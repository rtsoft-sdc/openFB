		<Attribute Name="Profile" Type="STRING" Value="HOLOBLOC"/>
		<Attribute Name="Color" Type="STRING" Value="192,203,83"/>
		<Resource Name="EMB_RES" Type="EMB_RES" x="0" y="0">
			<FBNetwork>
				<FB Name="washer_detectorApp.PUBLISH_1" Type="PUBLISH_1" x="3500" y="2100">
					<Parameter Name="QI" Value="TRUE"/>
					<Parameter Name="ID" Value="&quot;raw[].mqtt[tcp://localhost:1883, forte, d4]&quot;"/>
					<Parameter Name="SD_1" Value="STRING#'Hello, world!'"/>
				</FB>
				<FB Name="washer_detectorApp.E_SWITCH" Type="E_SWITCH" x="1100" y="2400">
					<Parameter Name="G" Value="TRUE"/>
