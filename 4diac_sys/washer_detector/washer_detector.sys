				<FB Name="washer_detectorApp.Detector_N_Drawer" Type="Detector_N_Drawer" x="3500" y="200">
					<Parameter Name="VIS" Value="TRUE"/>
					<Parameter Name="QUEUE_ID" Value="'q1'"/>
					<Parameter Name="MODEL_PTH" Value="'/home/orangepi/demo/w7.rknn'"/>
					<Parameter Name="CLASS_PTH" Value="'/home/orangepi/demo/names.txt'"/>
					<Parameter Name="ANCHORS_PTH" Value="'/home/orangepi/demo/RK_anchors.txt'"/>
